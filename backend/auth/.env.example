# Postgres settings
POSTGRES_HOST=auth_service_postgres
POSTGRES_PORT=5432
POSTGRES_USER=auth_service_user
POSTGRES_PASSWORD=12345678
POSTGRES_DB=auth_service_db

# Redis settings
REDIS_PREFIX=auth_service

# Minio settings
MINIO_BUCKET=auth_service

# Auth service settings
LOG_CONSOLE_OUT=true
LOG_PATH=/var/log/app/auth_service.log
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
ACCESS_TOKEN_LIFETIME=5h # 5m
REFRESH_TOKEN_LIFETIME=720h # 720h

# Argon2 concurrency limit (anti resource-exhaustion DoS).
# Peak hashing memory ≈ MAX_CONCURRENT_HASHES × 64 MiB — derive from the
# container memory limit, leaving headroom for the runtime/Redis/gRPC.
MAX_CONCURRENT_HASHES=8
# How long a request waits for a hashing slot before getting 503 (ResourceExhausted).
HASH_ACQUIRE_TIMEOUT=3s
