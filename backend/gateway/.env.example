# Gateway settings
LOG_CONSOLE_OUT=true
LOG_PATH=/var/log/app/gateway.log
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# MaxMind GeoLite2 — paths inside the container (volumes mounted in docker-compose)
GEOIP_CITY_DB_PATH=/etc/geoip/GeoLite2-City.mmdb
GEOIP_ASN_DB_PATH=/etc/geoip/GeoLite2-ASN.mmdb

# Rate limiting — token bucket (optional, defaults shown)
# CAPACITY — размер корзины (максимальный burst), REFILL — токенов в секунду (устойчивый rate)
# Password tier (login, register, restore, reset-password): limit by IP
RATE_LIMIT_PASSWORD_CAPACITY=120
RATE_LIMIT_PASSWORD_REFILL=2
# Code tier (verify, resend, forgot-password, 2fa, refresh): limit by IP
RATE_LIMIT_CODE_CAPACITY=240
RATE_LIMIT_CODE_REFILL=2
# User tier (authenticated endpoints): limit by userUUID
RATE_LIMIT_USER_CAPACITY=900
RATE_LIMIT_USER_REFILL=15

# Trusted reverse proxies (comma-separated IP/CIDR) allowed to set X-Forwarded-For.
# Empty = no trusted proxy, c.IP() always returns the direct connection IP
TRUSTED_PROXIES=172.18.0.0/16
